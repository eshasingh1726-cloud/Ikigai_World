    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search-input');
            const searchBtn = document.getElementById('search-btn');
            const weatherInfo = document.getElementById('weather-info');
            const airQuality = document.getElementById('air-quality');
            const loader = document.getElementById('loader');
            const errorMessage = document.getElementById('error-message');

            // OpenWeather API Key
            const apiKey = 'YOUR_OPENWEATHER_API_KEY'; // Replace with your actual API key

            // Format date
            function formatDate(date) {
                const options = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
                return date.toLocaleDateString('en-US', options);
            }

            // Get AQI description based on US EPA index
            function getAQIDescription(index) {
                const descriptions = [
                    "Good",
                    "Moderate",
                    "Unhealthy for sensitive groups",
                    "Unhealthy",
                    "Very Unhealthy",
                    "Hazardous"
                ];
                return `${index} - ${descriptions[index - 1] || "Unknown"}`;
            }

            // Fetch weather data
            async function fetchWeatherData(location) {
                // Use OpenWeather API
                const apiUrl = `https://api.openweathermap.org/data/2.5/weather?q=${location}&appid=${apiKey}&units=metric`;  // Change to metric

                try {
                    showLoader();
                    const response = await fetch(apiUrl);

                    if (!response.ok) {
                        throw new Error('Location not found');
                    }

                    const data = await response.json();
                    updateWeatherUI(data);
                    hideLoader();
                    showWeatherInfo();
                } catch (error) {
                    hideLoader();
                    showError(error.message);
                }
            }

            // Update UI with weather data from OpenWeatherMap
            function updateWeatherUI(data) {
                // Location and date
                document.getElementById('location').textContent = `${data.name}, ${data.sys.country}`; // короче тут меняем
                document.getElementById('date').textContent = formatDate(new Date());

                // Main weather info
                document.getElementById('temp').textContent = `${Math.round(data.main.temp)}°C`;  // And here
                const weatherIconCode = data.weather[0].icon;
                const weatherIconUrl = `https://openweathermap.org/img/wn/${weatherIconCode}@2x.png`; // And here
                document.getElementById('weather-icon').src = weatherIconUrl;
                document.getElementById('condition').textContent = data.weather[0].description;

                // Weather details
                document.getElementById('feels-like').textContent = `${Math.round(data.main.feels_like)}°C`; // And here
                document.getElementById('humidity').textContent = `${data.main.humidity}%`;
                document.getElementById('wind').textContent = `${data.wind.speed} m/s`;  // And here
                document.getElementById('pressure').textContent = `${data.main.pressure} hPa`;
                document.getElementById('visibility').textContent = `${data.visibility/1000} km`; // And here

                // UV Index - OpenWeatherMap doesn't directly provide UV, you might need a separate API
                document.getElementById('uv').textContent = 'N/A';

                // Air quality  -- OpenWeatherMap doesn't directly provide AQI, you might need a separate API or calculate from the components
                airQuality.style.display = 'none';
            }

            // Show loader
            function showLoader() {
                loader.style.display = 'flex';
                weatherInfo.style.display = 'none';
                airQuality.style.display = 'none';
                errorMessage.style.display = 'none';
            }

            // Hide loader
            function hideLoader() {
                loader.style.display = 'none';
            }

            // Show weather info
            function showWeatherInfo() {
                weatherInfo.style.display = 'block';
            }

            // Show error message
            function showError(message) {
                errorMessage.textContent = message;
                errorMessage.style.display = 'block';
                weatherInfo.style.display = 'none';
                airQuality.style.display = 'none';
            }

            // Event listeners
            searchBtn.addEventListener('click', function() {
                const location = searchInput.value.trim();
                if (location) {
                    fetchWeatherData(location);
                }
            });

            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const location = searchInput.value.trim();
                    if (location) {
                        fetchWeatherData(location);
                    }
                }
            });

            // Load default location on page load
            fetchWeatherData('India');
        });
    </script>
